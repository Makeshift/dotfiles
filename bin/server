#!/bin/bash
port=${1:-8000}

function python3_server() {
    if type -P python3 > /dev/null; then
        python3 -m http.server $1
    else
        python -m http.server $1
    fi
}

function python2_server() {
    if type -P python2 > /dev/null; then
        python2 -m SimpleHTTPServer $1
    else
        python -m SimpleHTTPServer $1
    fi
}

function node_server() {
    http-server . -p $1
}

function bash_server() {
    echo "Note: This server does not have a file list, you must go to files directly."
    echo|read|{(read t;g=$(echo $t|cut -d' ' -f2)
    while read|grep :;do :;done;[[ -e .$g &&! $g = *..* ]]||exit
    printf "HTTP/1.1 200 OK\nContent-Length: $(stat -c%s .$g)\n\n"
    cat .$g)|nc -l -p $1;}>/dev/fd/0;$0 $1
}

if ( type -P python3 > /dev/null || ( type -P python > /dev/null && "$(python --version)" =~ Python 3* )) && (( type -p python3 > /dev/null && python3 -m http.server $port ) || ( type -p python > /dev/null && python -m http.server $port )); then
    python3_server $port
elif type -p python2 > /dev/null  || ( type -P python > /dev/null && "$(python --version)" =~ Python 2* ); then
    python2_server $port
elif type -p npm > /dev/null && type -p node > /dev/null && npm install -g http-server > /dev/null; then
    node_server $port
else
    bash_server $port
fi