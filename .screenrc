bind c screen bash -ic 'HISTFILE=~/.bash_history.${WINDOW} bash'
bind ^C screen bash -ic 'HISTFILE=~/.bash_history.${WINDOW} bash'
startup_message off
defscrollback 32000
defutf8 on
mousetrack on
bindkey ^[[1;7D prev
bindkey ^[[1;7C next
hardstatus alwayslastline
hardstatus string "%-w%{= BW}%50>%n %t%{-}%+w%<"
nonblock on
altscreen on
attrcolor b ".I"
